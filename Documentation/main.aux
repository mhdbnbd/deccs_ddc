\@writefile{lof}{\contentsline {figure}{\numberline {2.1}{\ignorespaces One round of DECCS~\citep  {Miklautz2022}. (1) The encoder embeds data points $X$. (2) Clusterings are generated by applying ensemble members $\mathcal  {E}$ to the embedding $Z$. (3) Classifiers $g_i$ are trained to predict the cluster labels $\pi _i$ from $Z$. (4) $Z$ is updated by minimizing the loss $\mathcal  {L}$.}}{5}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:deccs}{{2.1}{5}{One round of DECCS~\citep {Miklautz2022}. (1) The encoder embeds data points $X$. (2) Clusterings are generated by applying ensemble members $\mathcal {E}$ to the embedding $Z$. (3) Classifiers $g_i$ are trained to predict the cluster labels $\pi _i$ from $Z$. (4) $Z$ is updated by minimizing the loss $\mathcal {L}$}{figure.caption.2}{}}
